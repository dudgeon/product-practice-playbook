{
  "name": "ai-pdlc-playbook",
  "version": "1.0.0",
  "description": "AI PDLC Playbook — a static site generated from JSON + Markdown content and reusable templates. Built from the Claude Design handoff.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node scripts/build-content.mjs && node src/build.mjs",
    "build-content": "node scripts/build-content.mjs",
    "render": "node src/build.mjs",
    "bootstrap": "node scripts/bootstrap-content.mjs",
    "serve": "node scripts/serve.mjs",
    "dev": "npm run build && node scripts/serve.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2"
  }
}
